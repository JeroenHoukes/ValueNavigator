# Value Navigator frontend – environment variables
# Copy to .env.local and fill in values. Do not commit .env.local.

# Microsoft Entra ID (Azure AD) – SPA app registration
NEXT_PUBLIC_AZURE_AD_CLIENT_ID=
NEXT_PUBLIC_AZURE_AD_TENANT_ID=

# Backend API base URL (no trailing slash)
# Local: http://localhost:5000
# Production: set to your deployed API URL when you deploy the backend (e.g. https://your-api.azurewebsites.net)
NEXT_PUBLIC_API_BASE_URL=http://localhost:5000

# When using protected API, set the API scope (e.g. api://<api-client-id>/.default)
# NEXT_PUBLIC_API_SCOPE=

# Azure SQL (optional – local API routes + schema Excel script introspect-azure-schema.cjs)
# AZURE_SQL_SERVER=yourserver.database.windows.net
# AZURE_SQL_DATABASE=ValueNavigator
# AZURE_SQL_USER=
# AZURE_SQL_PASSWORD=
